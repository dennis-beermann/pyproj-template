{
  "python.analysis.diagnosticsSource": "Pyright",
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.diagnosticMode": "openFilesOnly",

  "[python]": {
    "editor.wordWrap": "off",
    "editor.tabSize": 4,
    "editor.rulers": [88]
  },

  "[yaml]": {
    "editor.wordWrap": "off",
    "editor.tabSize": 2
  },

  "[json]": {
    "editor.wordWrap": "off",
    "editor.tabSize": 2
  },

  "[toml]": {
    "editor.wordWrap": "off",
    "editor.tabSize": 2
  }
}
