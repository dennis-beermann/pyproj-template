{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "pyright",
            "type": "shell",
            "command": "uv",
            "args": ["run", "pyright", "."],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },

        {
            "label": "ruff format",
            "type": "shell",
            "command": "uv",
            "args": ["run", "ruff", "format", "--check", "."],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },

        {
            "label": "ruff check",
            "type": "shell",
            "command": "uv",
            "args": ["run", "ruff", "check", "."],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
